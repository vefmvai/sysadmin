#!/usr/bin/env bash
# .githooks/pre-commit — версионируемый pre-commit hook репо sysadmin.
#
# ЗАЧЕМ. Персона агента двухслойна (выжимка sysadmin.md ↔ references/*.md).
# Рассинхрон между слоями = неправильное/пропущенное действие агента на старте
# (реальные инциденты v1.9.1–v1.9.3). Этот хук НЕ ДАЁТ закоммитить персону с
# рассинхроном: если в индексе есть правки персоны — прогоняет линтер
# check-persona-sync.sh и блокирует коммит при FAIL. Правило — CLAUDE.md
# «персона двухслойна».
#
# Хук версионируется (лежит в репо), активируется один раз:
#   git config core.hooksPath .githooks
# Эту строку добавляют sysadmin-init / bootstrap-new-server при настройке.
#
# Обход в исключительном случае (НЕ по привычке): git commit --no-verify

set -u

# --- корень репо -----------------------------------------------------------
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
LINTER="$ROOT/.claude/skills/_lib/check-persona-sync.sh"

# --- трогает ли этот коммит персону? --------------------------------------
# Смотрим staged-файлы. Линтер нужен, только если меняются выжимка или references.
STAGED="$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)"

PERSONA_TOUCHED=0
case "$STAGED" in
    *".claude/agents/sysadmin.md"*)            PERSONA_TOUCHED=1 ;;
esac
case "$STAGED" in
    *".claude/agents/references/"*)            PERSONA_TOUCHED=1 ;;
esac

if [ "$PERSONA_TOUCHED" -eq 0 ]; then
    exit 0   # персону не трогали — хук молча пропускает коммит
fi

# --- линтер на месте? ------------------------------------------------------
if [ ! -f "$LINTER" ]; then
    echo "⚠️  pre-commit: персона меняется, но линтер не найден ($LINTER) — пропускаю проверку." >&2
    exit 0
fi

# --- прогон линтера --------------------------------------------------------
echo "pre-commit: коммит трогает персону → проверяю согласованность слоёв…" >&2
if bash "$LINTER" --root "$ROOT" >&2; then
    exit 0
else
    echo >&2
    echo "❌ pre-commit ЗАБЛОКИРОВАН: персона рассинхронизирована (выжимка ↔ references)." >&2
    echo "   Синхронизируй выжимку sysadmin.md и references/ (см. CLAUDE.md «персона двухслойна»)," >&2
    echo "   затем повтори коммит. Осознанный обход (редко): git commit --no-verify" >&2
    exit 1
fi
