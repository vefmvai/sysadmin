# Личная конфигурация агента — НИКОГДА не коммитится в публичный репо.
# Содержит реальные SSH-алиасы, домены, имя Telegram-бота оператора.
sysadmin-config.json

# Публичные шаблоны и схема — коммитятся (negation override правила выше)
!sysadmin-config.example.json
!sysadmin-config.schema.json

# Мусор macOS
.DS_Store
._*

# Редакторские
.vscode/
.idea/
*.swp

# Claude Code служебные файлы
.claude/scheduled_tasks.lock

# Метка последней проверки обновлений (у каждого оператора своя)
.update-check

# Результаты прогона evals — артефакты сессии, не часть репо.
# Раннер — scripts/run-evals.sh (см. ADR-0004).
.eval-results/

# Временные артефакты ревизий и audit-сессий (Explore-агенты,
# промежуточные отчёты) — не часть репо.
.audit-tmp/
vpn-clients/
